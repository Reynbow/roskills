{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "rewrites": [
    { "source": "/skills", "destination": "/index.html" },
    { "source": "/skills/", "destination": "/index.html" },
    { "source": "/cards", "destination": "/cards.html" },
    { "source": "/cards/", "destination": "/cards.html" },
    { "source": "/pets", "destination": "/pets.html" },
    { "source": "/pets/", "destination": "/pets.html" },
    { "source": "/mounts", "destination": "/mounts.html" },
    { "source": "/mounts/", "destination": "/mounts.html" },
    { "source": "/armour", "destination": "/armour.html" },
    { "source": "/armour/", "destination": "/armour.html" },
    { "source": "/weapons", "destination": "/weapons.html" },
    { "source": "/weapons/", "destination": "/weapons.html" },
    { "source": "/monsters", "destination": "/monsters.html" },
    { "source": "/monsters/", "destination": "/monsters.html" }
  ]
}
