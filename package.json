{
  "name": "ro-pre-renewal-skill-planner",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "setup-fonts": "node scripts/setup-web-fonts.mjs",
    "import-skillinfo": "node scripts/import-skillinfo.mjs",
    "build:navi-defaults": "node scripts/build-navi-defaults.mjs",
    "build:mob-maps": "node scripts/build-mob-spawn-maps.mjs",
    "import-cards": "node scripts/import-cards.mjs",
    "fetch:card-affixes": "node scripts/fetch-card-affixes.mjs",
    "import-pets": "node scripts/import-pets.mjs",
    "import-data": "node scripts/import-skillinfo.mjs && node scripts/import-cards.mjs && node scripts/import-pets.mjs",
    "predev": "node scripts/import-skillinfo.mjs",
    "prebuild": "node scripts/import-skillinfo.mjs",
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "setup:zrenderer": "node scripts/download-zrenderer.mjs",
    "render:job-sit": "node scripts/render-job-sit-sprites.mjs",
    "render:job-sit:print": "node scripts/render-job-sit-sprites.mjs --print-only",
    "render:job-sit:skip": "node scripts/render-job-sit-sprites.mjs --skip-existing",
    "fix:ro-sprite-names": "node scripts/fix-ro-sprite-cp949-names.mjs"
  },
  "devDependencies": {
    "iconv-lite": "^0.7.2",
    "typescript": "~5.9.3",
    "vite": "^8.0.1",
    "yaml": "^2.8.3"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1"
  }
}
